rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Chaque utilisateur ne lit/écrit que son propre document.
    // Phase 1 (test) : le client peut poser premium via le code promo.
    // Phase 2 (lancement) : durcir en interdisant l'écriture de "premium"
    //   côté client (seule la Cloud Function, en admin, l'écrira).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
